{
  "name": "@layeroi/sdk",
  "version": "0.1.0",
  "description": "Layeroi SDK — auto-instrument AI agent LLM calls with cost, latency, and task attribution",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true }
  },
  "devDependencies": {
    "openai": "^4.28.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["layeroi", "ai", "agent", "cost", "observability", "openai", "sdk"],
  "repository": {
    "type": "git",
    "url": "https://github.com/hridhaygarg/Layeroi.git",
    "directory": "packages/sdk-typescript"
  }
}
