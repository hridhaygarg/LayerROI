{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "ls -la node_modules/.bin/ | grep react-scripts && cat package.json | grep -A2 'react-scripts' && npm ls react-scripts && CI=false react-scripts build",
  "rewrites": [
    { "source": "/static/:path*", "destination": "/static/:path*" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/asset-manifest.json", "destination": "/asset-manifest.json" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "env": {
    "CI": "false"
  }
}
